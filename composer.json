{
	"name": "regionallyfamous/bouncer",
	"description": "WordPress plugin: per-plugin behavior monitoring",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"php-parallel-lint/php-parallel-lint": "^1.4",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"squizlabs/php_codesniffer": "^3.10",
		"wp-coding-standards/wpcs": "^3.1"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	},
	"scripts": {
		"phpcs": "phpcs",
		"phpcbf": "phpcbf",
		"phpcs:compat": "phpcs --standard=./phpcs-compat.xml.dist",
		"lint:syntax": "parallel-lint --exclude vendor --exclude dev-environment .",
		"lint:php": [
			"@lint:syntax",
			"@phpcs"
		],
		"lint": [
			"@lint:php",
			"@phpcs:compat"
		]
	}
}
