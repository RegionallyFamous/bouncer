<?xml version="1.0"?>
<ruleset name="Bouncer PHP Compatibility">
	<description>PHP cross-version compatibility for WordPress (includes db.php drop-in).</description>

	<file>.</file>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/dev-environment/*</exclude-pattern>

	<arg name="extensions" value="php"/>
	<arg name="cache" value=".phpcs-cache"/>
	<arg value="ps"/>

	<config name="testVersion" value="8.1-"/>
	<config name="minimum_supported_wp_version" value="7.0"/>

	<rule ref="PHPCompatibilityWP"/>
</ruleset>
